                      "spec": {
                        "query": "from(bucket: \"pi_sensors\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"plant_environment\")\n  |> filter(fn: (r) => r.location == \"plant_shelf\")\n  |> filter(fn: (r) => r._field == \"soil_moisture_voltage\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
                      }
